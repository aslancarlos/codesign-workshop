# Code Signing Workshop — configuration template.
# Copy to .env and edit. Load with:  set -a; . ./.env; set +a
#
# NOTHING here is secret by itself, but KEYFILE/API_TOKEN_FILE point at secrets.
# Keep the real .env out of version control (.gitignore already excludes it).

# --- Identity / authentication --------------------------------------------
# Service account UUID used to authenticate (required for the login step).
CLIENT_ID=""

# Service account private key (PEM) generated when you created the account.
KEYFILE="$HOME/.codesign/service_account.key"

# Optional: a file containing an API key. Enables the API-backed steps
# (central key inventory, signers, per-key signature counts).
API_TOKEN_FILE="$HOME/.codesign/api_token"

# --- Project / keys --------------------------------------------------------
# Signing key label exactly as shown by `pkcs11config list`.
LABEL_SIGN="signing-key"
# Certificate label to download (defaults to LABEL_SIGN).
LABEL_CERT="signing-key"
# Code Sign project name (used in API queries and console hints).
PROJECT="my-project"
# Friendly display name for the signing identity (shown in the UI and logs).
IDENTITY="signer"

# --- Platform / region -----------------------------------------------------
# Tenant / URL prefix (optional; only shown in console hints when set).
TENANT=""
# API region base URL. US default; EU/AU/UK/SG/CA tenants use a different host.
API_BASE="https://api.venafi.cloud"

# --- Local paths -----------------------------------------------------------
# PKCS#11 module shipped with the Code Sign Manager client.
MODULE="/opt/venafi/codesign/lib/venafipkcs11.so"
# OpenSSL pkcs11 engine.
ENGINE_SO="/usr/lib/x86_64-linux-gnu/engines-3/pkcs11.so"
# Working directory for generated artifacts.
WORK="/tmp/codesign_demo"

# --- Presentation ----------------------------------------------------------
# Banner / title text.
BRAND="Machine Identity - Code Signing Workshop"
# UI language: pt | es. Leave empty to be asked at startup.
DEMO_LANG=""
# PKCS#11 PIN — a dummy value; real auth is the cloud grant. Leave as-is.
PKCS11_PIN="1234"
